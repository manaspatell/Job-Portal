<%- include('partials/header') %>

<main class="pricing-layout">
  <!-- Authentication Modal (shown first) -->
  <div id="authModal" class="auth-modal" style="display: flex;">
    <div class="auth-modal-overlay"></div>
    <div class="auth-modal-content">
      <div class="auth-card">
        <h2 class="auth-title">🔒 Verify Your Identity</h2>
        <p class="auth-subtitle">Please login to renew your subscription</p>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error">
            <%= error %>
          </div>
        <% } %>

        <form id="authForm" class="auth-form">
          <div class="form-group">
            <label for="email" class="form-label">School Email</label>
            <input 
              id="email" 
              name="email" 
              type="email" 
              class="form-control" 
              placeholder="your-school@example.com"
              required
              value="<%= typeof email !== 'undefined' ? email : '' %>"
            >
          </div>

          <div class="form-group">
            <label for="password" class="form-label">Password</label>
            <input 
              id="password" 
              name="password" 
              type="password" 
              class="form-control" 
              placeholder="Enter your password"
              required
            >
          </div>

          <button type="submit" class="btn-auth">
            <span>Verify Identity</span>
            <span class="btn-arrow">→</span>
          </button>
        </form>

        <div class="auth-footer">
          <a href="/school/login" class="link-back">← Back to Login</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Pricing Section (hidden until authenticated) -->
  <div id="pricingSection" class="pricing-container" style="display: none;">
    <div class="pricing-header-content">
      <div class="verified-badge">
        <span class="verified-icon">✓</span>
        <span class="verified-text">Verified: <span id="schoolNameDisplay"></span></span>
      </div>
      <h1 class="pricing-title">Renew Your Subscription</h1>
      <p class="pricing-subtitle">Choose your plan and continue hiring great teachers</p>
    </div>

    <div class="pricing-cards">
      <% 
        const plans = [
          { id: 'silver', name: 'Silver', featured: false },
          { id: 'gold', name: 'Gold', featured: true },
          { id: 'diamond', name: 'Diamond', featured: false }
        ];
        
        plans.forEach(plan => {
      %>
      <!-- <%= plan.name %> Plan -->
      <div class="pricing-card <%= plan.id %>-plan <%= plan.featured ? 'featured' : '' %>" data-plan="<%= plan.name %>">
        <% if (plan.featured) { %>
          <div class="plan-badge">Most Popular</div>
        <% } %>

        <div class="plan-header">
          <h3 class="plan-name"><%= plan.name %></h3>
          <p class="plan-description" id="<%= plan.id %>-description">Professional plan</p>
        </div>

        <div class="plan-price">
          <span class="original-price" id="<%= plan.id %>-base-price" style="display: none;"></span>
          <span class="price-amount" id="<%= plan.id %>-price">₹0</span>
          <span class="price-period">/<span id="<%= plan.id %>-duration">month</span></span>
        </div>

        <div class="discount-banner" id="<%= plan.id %>-discount" style="display: none;">
          Save <span class="discount-amount"></span>
        </div>

        <p class="plan-tagline">
          <% if (plan.id === 'silver') { %>
            Get started with basic features
          <% } else if (plan.id === 'gold') { %>
            Everything you need to scale
          <% } else { %>
            Maximum power and flexibility
          <% } %>
        </p>

        <button class="plan-button <%= plan.featured ? 'featured-button' : '' %>" onclick="selectPlan('<%= plan.name %>', '<%= plan.id %>')">
          Renew Now
        </button>

        <div class="plan-features" id="<%= plan.id %>-features">
          <!-- Features will be loaded dynamically -->
        </div>
      </div>
      <% }) %>
    </div>

    <!-- Previous Subscription Info -->
    <div class="info-section">
      <h3 class="info-title">📊 Your Previous Subscription</h3>
      <div class="info-grid">
        <div class="info-item">
          <span class="info-label">Previous Plan:</span>
          <span class="info-value" id="previousPlan">—</span>
        </div>
        <div class="info-item">
          <span class="info-label">Expired On:</span>
          <span class="info-value" id="expiryDate">—</span>
        </div>
        <div class="info-item">
          <span class="info-label">Status:</span>
          <span class="info-value"><span class="status-badge expired" id="previousStatus">Expired</span></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Payment Modal -->
  <div id="paymentModal" class="payment-modal" style="display: none;">
    <div class="payment-modal-overlay" onclick="closePaymentModal()"></div>
    <div class="payment-modal-content">
      <button class="modal-close-btn" onclick="closePaymentModal()">✕</button>
      
      <div class="payment-header">
        <h2>Complete Your Payment</h2>
        <p>Scan QR code and upload payment proof</p>
      </div>

      <div class="payment-body">
        <div class="payment-summary">
          <div class="summary-item">
            <span>Selected Plan:</span>
            <strong id="selectedPlanName">Gold</strong>
          </div>
          <div class="summary-item">
            <span>Amount:</span>
            <strong id="selectedPlanPrice">₹25,000</strong>
          </div>
        </div>

        <div class="qr-section">
          <h3>Scan to Pay</h3>
          <div class="qr-box">
              <img src="/uploads/bank/QR.jpeg" alt="Bank QR Code" class="qr-image"
                onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22><rect width=%22200%22 height=%22200%22 fill=%22%23f0f0f0%22/><text x=%2250%25%22 y=%2250%25%22 text-anchor=%22middle%22 dy=%22.3em%22 fill=%22%23999%22 font-size=%2214%22>QR Code</text></svg>'">
          </div>
          <!-- Payment method icons removed as requested -->
        </div>

        <form id="paymentForm" class="payment-form" enctype="multipart/form-data">
          <input type="hidden" id="schoolId" name="schoolId">
          <input type="hidden" id="schoolEmail" name="schoolEmail">
          <input type="hidden" id="selectedPlan" name="plan">

          <div class="form-group">
            <label for="phone" class="form-label">Contact Number</label>
            <input 
              id="phone" 
              name="phone" 
              type="tel" 
              class="form-control" 
              placeholder="+91 XXXXX XXXXX"
              required
            >
          </div>

          <div class="form-group">
            <label for="paymentScreenshot" class="form-label">Payment Screenshot</label>
            <div class="file-upload">
              <input 
                id="paymentScreenshot" 
                name="paymentScreenshot" 
                type="file" 
                class="file-input" 
                accept="image/*"
                required
              >
              <div class="file-upload-area">
                <span class="upload-icon">📸</span>
                <span class="upload-text">Click to upload</span>
                <span class="upload-hint">PNG, JPG up to 5MB</span>
              </div>
            </div>
            <div class="file-name" id="fileName"></div>
          </div>

          <button type="submit" class="btn-submit">
            <span>Submit Payment Proof</span>
          </button>

          <p class="form-note">
            ℹ️ Your payment will be verified and your subscription activated within 2-4 hours.<br>
            📱 Once verified, you will receive a confirmation and further instructions via WhatsApp. Thank you for your patience!
          </p>
        </form>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="pricing-footer">
    <p class="footer-text">© 2026 Teacher Recruitment Management System. All rights reserved.</p>
  </div>
</main>

