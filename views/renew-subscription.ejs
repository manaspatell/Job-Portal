    .pricing-card.featured {
      transform: scale(1);
    }

    .info-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .pricing-container {
      padding: 40px 20px;
    }

    .pricing-title {
      font-size: 32px;
    }

    .pricing-subtitle {
      font-size: 16px;
    }

    .auth-card {
      padding: 32px 24px;
    }

    .payment-modal-content {
      margin: 0 16px;
    }

    .payment-header,
    .payment-body {
      padding: 24px;
    }
  }
</style>

<script>
  let verifiedSchool = null;
  let pricingData = {};

  // Load pricing data
  async function loadPricing() {
    try {
      const response = await fetch('/api/pricing');
      if (response.ok) {
        pricingData = await response.json();
        updatePricingDisplay();
      }
    } catch (error) {
      console.error('Error loading pricing:', error);
    }
  }

  function updatePricingDisplay() {
    ['silver', 'gold', 'diamond'].forEach(planId => {
      const planData = pricingData[planId];
      if (planData) {
        const finalPrice = planData.currentPrice || planData.basePrice || 0;
        const basePrice = planData.basePrice || 0;
        const discount = planData.discount || 0;
        const discountType = planData.discountType || 'percentage';

        // Update price
        document.getElementById(`${planId}-price`).textContent = 
          '₹' + finalPrice.toLocaleString('en-IN');

        // Update duration
        document.getElementById(`${planId}-duration`).textContent = planData.duration || 'month';

        // Update description
        document.getElementById(`${planId}-description`).textContent = 
          planData.description || 'Professional plan';

        // Show discount if applicable
        if (discount > 0) {
          const basePriceEl = document.getElementById(`${planId}-base-price`);
          basePriceEl.textContent = '₹' + basePrice.toLocaleString('en-IN');
          basePriceEl.style.display = 'inline';

          const discountEl = document.getElementById(`${planId}-discount`);
          const savings = discountType === 'percentage' ? 
            Math.round(basePrice * discount / 100) : discount;
          discountEl.querySelector('.discount-amount').textContent = 
            '₹' + savings.toLocaleString('en-IN') + ' | ' + discount + (discountType === 'percentage' ? '%' : '') + ' OFF';
          discountEl.style.display = 'block';
        }

        // Update features
        const featuresContainer = document.getElementById(`${planId}-features`);
        if (planData.features && planData.features.length > 0) {
          featuresContainer.innerHTML = planData.features.map(feature => `
            <div class="feature">
              <span class="check-icon">✓</span>
              <span>${feature}</span>
            </div>
          `).join('');
        }
      }
    });
  }

  // Handle authentication
  document.getElementById('authForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const authBtn = e.target.querySelector('.btn-auth');
    authBtn.disabled = true;
    authBtn.innerHTML = '<span>Verifying...</span>';

    const formData = new FormData(e.target);
    const email = formData.get('email');
    const password = formData.get('password');

    try {
      const response = await fetch('/api/verify-school', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password })
      });

      const result = await response.json();

      if (result.success) {
        verifiedSchool = result.school;

        // Prefer lastSubscription for previous plan info
        let prevPlan = '—';
        let prevExpiry = '—';
        let prevStatus = '—';
        if (result.school.lastSubscription && result.school.lastSubscription.tier && result.school.lastSubscription.tier !== 'none') {
          prevPlan = result.school.lastSubscription.tier.toUpperCase();
          prevExpiry = result.school.lastSubscription.endDate ? new Date(result.school.lastSubscription.endDate).toLocaleDateString() : 'N/A';
          prevStatus = result.school.lastSubscription.status ? result.school.lastSubscription.status.charAt(0).toUpperCase() + result.school.lastSubscription.status.slice(1) : 'Expired';
        } else if (result.school.subscription && result.school.subscription.tier && result.school.subscription.tier !== 'none') {
          prevPlan = result.school.subscription.tier.toUpperCase();
          prevExpiry = result.school.subscription.endDate ? new Date(result.school.subscription.endDate).toLocaleDateString() : 'N/A';
          prevStatus = result.school.subscription.status ? result.school.subscription.status.charAt(0).toUpperCase() + result.school.subscription.status.slice(1) : 'Expired';
        }
        document.getElementById('schoolNameDisplay').textContent = result.school.name;
        document.getElementById('previousPlan').textContent = prevPlan;
        document.getElementById('expiryDate').textContent = prevExpiry;
        document.getElementById('previousStatus').textContent = prevStatus;

        // Hide auth modal and show pricing section
        document.getElementById('authModal').style.display = 'none';
        document.getElementById('pricingSection').style.display = 'block';

        // Set hidden fields for later
        document.getElementById('schoolId').value = result.school.id;
        document.getElementById('schoolEmail').value = result.school.email;
      } else {
        alert(result.message || 'Authentication failed. Please check your credentials.');
        authBtn.disabled = false;
        authBtn.innerHTML = '<span>Verify Identity</span><span class="btn-arrow">→</span>';
      }
    } catch (error) {
      console.error('Auth error:', error);
      alert('Error verifying credentials. Please try again.');
      authBtn.disabled = false;
      authBtn.innerHTML = '<span>Verify Identity</span><span class="btn-arrow">→</span>';
    }
  });

  // Handle plan selection
  function selectPlan(planName, planId) {
    if (!verifiedSchool) {
      alert('Please authenticate first');
      return;
    }

    const planData = pricingData[planId];
    const finalPrice = planData?.currentPrice || planData?.basePrice || 0;

    // Update payment modal
    document.getElementById('selectedPlanName').textContent = planName;
    document.getElementById('selectedPlanPrice').textContent = '₹' + finalPrice.toLocaleString('en-IN');
    document.getElementById('selectedPlan').value = planName;

    // Show payment modal
    document.getElementById('paymentModal').style.display = 'flex';
  }

  function closePaymentModal() {
    document.getElementById('paymentModal').style.display = 'none';
  }

  // Handle file upload display
  document.getElementById('paymentScreenshot').addEventListener('change', (e) => {
    const fileName = e.target.files[0]?.name || '';
    document.getElementById('fileName').textContent = fileName ? `Selected: ${fileName}` : '';
  });

  // Handle payment form submission
  document.getElementById('paymentForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitBtn = e.target.querySelector('.btn-submit');
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span>Submitting...</span>';

    const formData = new FormData(e.target);

    try {
      const response = await fetch('/api/submit-renewal', {
        method: 'POST',
        body: formData
      });

      const result = await response.json();

      if (result.success) {
        alert('Renewal payment submitted successfully! Admin will verify and activate your subscription within 2-4 hours.');
        window.location.href = '/school/login';
      } else {
        alert(result.message || 'Error submitting renewal payment.');
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<span>Submit Payment Proof</span>';
      }
    } catch (error) {
      console.error('Submission error:', error);
      alert('Error submitting renewal. Please try again.');
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span>Submit Payment Proof</span>';
    }
  });

  // Load pricing on page load
  loadPricing();

  // Pre-fill email if provided in URL
  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const email = urlParams.get('email');
    if (email) {
      document.getElementById('email').value = email;
    }
  });
</script>

<%- include('partials/footer') %>
