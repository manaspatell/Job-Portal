<%- include('partials/header') %>
<main class="admin-layout">
  <section class="content">
    <div class="page-header">
      <h1>Payment Proofs</h1>
      <p class="subtext">Review and approve pending payments. Once approved, create credentials for the school.</p>
    </div>

    <div class="table-card">
      <table class="payments-table">
        <thead>
          <tr>
            <th>Institute</th>
            <th>Plan</th>
            <th>Phone</th>
            <th>WhatsApp</th>
            <th>Email</th>
            <th>Status</th>
            <th>Submitted</th>
            <th>Screenshot</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (!payments || payments.length === 0) { %>
            <tr>
              <td colspan="9" class="empty-row">No payments submitted yet.</td>
            </tr>
          <% } else { %>
            <% payments.forEach(p => { %>
              <tr>
                <td><strong><%= p.instituteName %></strong></td>
                <td><span class="plan-badge"><%= p.plan %></span></td>
                <td><%= p.phone %></td>
                <td><%= p.whatsapp %></td>
                <td><%= p.email %></td>
                <td>
                  <% if (p.status === 'approved') { %>
                    <span class="badge badge-approved">✓ Approved</span>
                  <% } else { %>
                    <span class="badge badge-pending">⏳ Pending</span>
                  <% } %>
                </td>
                <td class="date-col"><%= new Date(p.submittedAt).toLocaleDateString() %></td>
                <td>
                  <% if (p.screenshot) { %>
                    <a href="/uploads/payment-proofs/<%= p.screenshot %>" target="_blank" class="link">View</a>
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td class="action-cell">
                  <% if (p.status === 'pending') { %>
                    <form method="POST" action="/admin/payments/<%= p.id %>/approve" style="display: inline;">
                      <button type="submit" class="btn-small btn-approve" title="Approve payment">Approve</button>
                    </form>
                  <% } else { %>
                    <button type="button" class="btn-small btn-create" onclick="openCredentialsModal('<%= p.id %>', '<%= p.instituteName %>', '<%= p.whatsapp %>')" title="Create credentials for this school">Create Credentials</button>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>
</main>

<!-- Credentials Modal -->
<div id="credentialsModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Create School Credentials</h2>
      <button type="button" class="modal-close" onclick="closeCredentialsModal()">&times;</button>
    </div>
    <div class="modal-body">
      <form id="credentialsForm">
        <div class="form-group">
          <label for="instituteName">School/Institute Name</label>
          <input type="text" id="instituteName" name="institute" class="form-control" readonly>
        </div>

        <div class="form-group">
          <label for="contactPhone">Contact Phone</label>
          <input type="text" id="contactPhone" name="contact" class="form-control" readonly>
        </div>

        <div class="form-group">
          <label for="credentialEmail">Login Email *</label>
          <input type="email" id="credentialEmail" name="email" class="form-control" placeholder="Enter school login email" required>
          <small class="form-text">This email will be used for school login</small>
        </div>

        <div class="form-group">
          <label for="credentialPassword">Password *</label>
          <input type="password" id="credentialPassword" name="password" class="form-control" placeholder="Enter strong password" required>
          <small class="form-text">Min 8 chars, uppercase, lowercase, number, special char</small>
        </div>

        <div class="form-group">
          <label for="confirmPassword">Confirm Password *</label>
          <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="Confirm password" required>
        </div>

        <input type="hidden" id="paymentId" name="paymentId">

        <div class="form-error" id="formError" style="display: none;"></div>
      </form>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn btn-cancel" onclick="closeCredentialsModal()">Cancel</button>
      <button type="button" class="btn btn-primary" onclick="submitCredentialsForm()">Create Credentials</button>
    </div>
  </div>
</div>

<style>
  .admin-layout {
    padding: 20px;
    background: #f5f7fb;
    min-height: 100vh;
  }

  .content {
    max-width: 1400px;
    margin: 0 auto;
  }

  .page-header h1 {
    margin: 0 0 6px;
    font-size: 28px;
    font-weight: 700;
    color: #2c3e50;
  }

  .subtext {
    margin: 0 0 24px;
    color: #7f8c8d;
    font-size: 14px;
    font-weight: 500;
  }

  .table-card {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    border: 1px solid #e8ecf1;
    overflow: auto;
  }

  .payments-table {
    width: 100%;
    border-collapse: collapse;
  }

  .payments-table th, .payments-table td {
    padding: 14px 16px;
    text-align: left;
    font-size: 13px;
    color: #2c3e50;
    border-bottom: 1px solid #f0f3f8;
  }

  .payments-table th {
    background: #f8fbff;
    font-weight: 700;
    color: #34495e;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  .empty-row {
    text-align: center;
    color: #95a5a6;
    padding: 30px;
    font-style: italic;
  }

  .date-col {
    white-space: nowrap;
  }

  .plan-badge {
    background: linear-gradient(135deg, #0066cc 0%, #0052a3 100%);
    color: white;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 700;
  }

  .badge {
    padding: 6px 12px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 12px;
    display: inline-block;
    white-space: nowrap;
  }

  .badge-pending {
    background: #fff5e6;
    color: #b36b00;
  }

  .badge-approved {
    background: #e8f8f2;
    color: #1e8449;
  }

  .action-cell {
    white-space: nowrap;
    display: flex;
    gap: 6px;
  }

  .btn-small {
    padding: 8px 12px;
    border: none;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .btn-approve {
    background: linear-gradient(135deg, #0066cc 0%, #0052a3 100%);
    color: #fff;
    box-shadow: 0 4px 12px rgba(0, 102, 204, 0.25);
  }

  .btn-approve:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 102, 204, 0.35);
  }

  .btn-create {
    background: linear-gradient(135deg, #27ae60 0%, #1e8449 100%);
    color: #fff;
    box-shadow: 0 4px 12px rgba(39, 174, 96, 0.25);
  }

  .btn-create:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(39, 174, 96, 0.35);
  }

  .link {
    color: #0066cc;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .link:hover {
    text-decoration: underline;
    color: #0052a3;
  }

  /* Modal Styles */
  .modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.4);
    animation: fadeIn 0.2s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .modal.active {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-content {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    width: 90%;
    max-width: 500px;
    animation: slideUp 0.3s ease;
  }

  @keyframes slideUp {
    from {
      transform: translateY(20px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .modal-header {
    padding: 24px;
    border-bottom: 1px solid #e8ecf1;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .modal-header h2 {
    margin: 0;
    font-size: 20px;
    font-weight: 700;
    color: #2c3e50;
  }

  .modal-close {
    background: none;
    border: none;
    font-size: 28px;
    color: #7f8c8d;
    cursor: pointer;
    padding: 0;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
  }

  .modal-close:hover {
    color: #2c3e50;
  }

  .modal-body {
    padding: 24px;
  }

  .form-group {
    margin-bottom: 18px;
  }

  .form-group label {
    display: block;
    margin-bottom: 6px;
    font-weight: 700;
    color: #2c3e50;
    font-size: 14px;
  }

  .form-control {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #d0d7e0;
    border-radius: 8px;
    font-size: 14px;
    color: #2c3e50;
    font-family: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
  }

  .form-control:focus {
    outline: none;
    border-color: #0066cc;
    box-shadow: 0 0 0 3px rgba(0,102,204,0.1);
  }

  .form-control:readonly {
    background: #f8fbff;
    color: #7f8c8d;
  }

  .form-text {
    display: block;
    margin-top: 4px;
    font-size: 12px;
    color: #7f8c8d;
  }

  .form-error {
    padding: 12px;
    background: #fee;
    color: #c33;
    border-radius: 8px;
    font-size: 13px;
    margin-bottom: 12px;
  }

  .modal-footer {
    padding: 16px 24px;
    border-top: 1px solid #e8ecf1;
    display: flex;
    gap: 12px;
    justify-content: flex-end;
  }

  .btn {
    padding: 10px 20px;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .btn-cancel {
    background: #f0f3f8;
    color: #2c3e50;
  }

  .btn-cancel:hover {
    background: #e8ecf1;
  }

  .btn-primary {
    background: linear-gradient(135deg, #0066cc 0%, #0052a3 100%);
    color: #fff;
    box-shadow: 0 4px 12px rgba(0, 102, 204, 0.25);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 102, 204, 0.35);
  }

  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (max-width: 1024px) {
    .table-card {
      overflow-x: auto;
    }

    .payments-table th, .payments-table td {
      padding: 10px 12px;
      font-size: 12px;
    }

    .modal-content {
      width: 95%;
      max-width: 450px;
    }
  }
</style>

<script>
  function openCredentialsModal(paymentId, instituteName, whatsapp) {
    document.getElementById('paymentId').value = paymentId;
    document.getElementById('instituteName').value = instituteName;
    document.getElementById('contactPhone').value = whatsapp;
    document.getElementById('credentialEmail').value = '';
    document.getElementById('credentialPassword').value = '';
    document.getElementById('confirmPassword').value = '';
    document.getElementById('formError').style.display = 'none';
    document.getElementById('credentialsModal').classList.add('active');
  }

  function closeCredentialsModal() {
    document.getElementById('credentialsModal').classList.remove('active');
  }

  function submitCredentialsForm() {
    const form = document.getElementById('credentialsForm');
    const institute = document.getElementById('instituteName').value;
    const contact = document.getElementById('contactPhone').value;
    const email = document.getElementById('credentialEmail').value;
    const password = document.getElementById('credentialPassword').value;
    const confirmPassword = document.getElementById('confirmPassword').value;
    const paymentId = document.getElementById('paymentId').value;

    const errorDiv = document.getElementById('formError');

    // Validation
    if (!email) {
      errorDiv.textContent = 'Email is required';
      errorDiv.style.display = 'block';
      return;
    }

    if (!password) {
      errorDiv.textContent = 'Password is required';
      errorDiv.style.display = 'block';
      return;
    }

    if (password !== confirmPassword) {
      errorDiv.textContent = 'Passwords do not match';
      errorDiv.style.display = 'block';
      return;
    }

    const submitBtn = event.target;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating...';

    fetch('/admin/payments/create-credentials', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({
        paymentId,
        institute,
        contact,
        email,
        password,
        confirmPassword
      })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        alert('Credentials created successfully! School can now login with the email and password.');
        closeCredentialsModal();
        window.location.reload();
      } else {
        errorDiv.textContent = data.error || 'Failed to create credentials';
        errorDiv.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create Credentials';
      }
    })
    .catch(err => {
      console.error('Error:', err);
      errorDiv.textContent = 'An error occurred. Please try again.';
      errorDiv.style.display = 'block';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Create Credentials';
    });
  }

  // Close modal when clicking outside
  document.addEventListener('click', (e) => {
    const modal = document.getElementById('credentialsModal');
    if (e.target === modal) {
      closeCredentialsModal();
    }
  });
</script>

<%- include('partials/footer') %>
