  }

  .btn-renew:active {
    transform: translateY(0);
  }

  .btn-arrow {
    font-size: 18px;
  }

</style>

<script>
  function openCredentialsModal() {
    document.getElementById('emailModal').style.display = 'flex';
  }

  function closeCredentialsModal() {
    document.getElementById('emailModal').style.display = 'none';
  }

  // Close modal when clicking outside
  document.getElementById('emailModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeCredentialsModal();
    }
  });

  // Handle form submission
  document.getElementById('emailForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const email = document.getElementById('userEmail').value;
    // Store email in localStorage for tracking
    localStorage.setItem('userEmail', email);
    // Redirect to subscription pricing page
    window.location.href = '/subscription-pricing?email=' + encodeURIComponent(email);
  });

  // Close modal with Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeCredentialsModal();
      closeTrackProgressModal();
    }
  });

  // Track Progress Functions
  function openTrackProgressModal() {
    document.getElementById('trackProgressModal').style.display = 'flex';
    document.getElementById('trackEmail').focus();
  }

  function closeTrackProgressModal() {
    document.getElementById('trackProgressModal').style.display = 'none';
    document.getElementById('trackForm').reset();
    document.getElementById('trackingResult').style.display = 'none';
    document.getElementById('trackingError').style.display = 'none';
  }

  // Close track modal when clicking outside
  document.getElementById('trackProgressModal').addEventListener('click', function(e) {
    if (e.target === this) {
      closeTrackProgressModal();
    }
  });

  // Handle track form submission
  document.getElementById('trackForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const email = document.getElementById('trackEmail').value;
    const submitBtn = this.querySelector('button[type="submit"]');
    const originalText = submitBtn.textContent;
    
    submitBtn.disabled = true;
    submitBtn.textContent = 'Checking...';

    fetch('/api/track-payment?email=' + encodeURIComponent(email))
      .then(res => res.json())
      .then(data => {
        document.getElementById('trackingError').style.display = 'none';
        
        if (data.success && data.payment) {
          const payment = data.payment;
          let statusHtml = '<h3>✓ Payment Found</h3>';
          
          statusHtml += '<div class="status-item">';
          statusHtml += '<div class="status-icon completed">✓</div>';
          statusHtml += '<div class="status-text">';
          statusHtml += '<div class="status-label">Institute Name</div>';
          statusHtml += '<div class="status-value">' + payment.instituteName + '</div>';
          statusHtml += '</div></div>';

          statusHtml += '<div class="status-item">';
          statusHtml += '<div class="status-icon completed">✓</div>';
          statusHtml += '<div class="status-text">';
          statusHtml += '<div class="status-label">Subscription Plan</div>';
          statusHtml += '<div class="status-value">' + payment.plan + '</div>';
          statusHtml += '</div></div>';

          const submittedDate = new Date(payment.submittedAt).toLocaleDateString('en-US', { 
            year: 'numeric', month: 'long', day: 'numeric' 
          });
          statusHtml += '<div class="status-item">';
          statusHtml += '<div class="status-icon completed">✓</div>';
          statusHtml += '<div class="status-text">';
          statusHtml += '<div class="status-label">Submitted On</div>';
          statusHtml += '<div class="status-value">' + submittedDate + '</div>';
          statusHtml += '</div></div>';

          statusHtml += '<div class="status-item">';
          if (payment.status === 'approved') {
            statusHtml += '<div class="status-icon completed">✓</div>';
            statusHtml += '<div class="status-text">';
            statusHtml += '<div class="status-label">Verification Status</div>';
            statusHtml += '<div class="status-value">Approved <span class="status-badge approved">APPROVED</span></div>';
            statusHtml += '<div class="status-value" style="margin-top: 6px;">Your credentials are ready! You can now login to the system.</div>';
            statusHtml += '</div></div>';
          } else {
            statusHtml += '<div class="status-icon pending">⏳</div>';
            statusHtml += '<div class="status-text">';
            statusHtml += '<div class="status-label">Verification Status</div>';
            statusHtml += '<div class="status-value">Pending <span class="status-badge pending">PENDING</span></div>';
            statusHtml += '<div class="status-value" style="margin-top: 6px;">Our team is reviewing your submission. We typically verify within 1-2 days. We\'ll update you via WhatsApp.</div>';
            statusHtml += '</div></div>';
          }

          document.getElementById('resultContent').innerHTML = statusHtml;
          document.getElementById('trackingResult').style.display = 'block';
        } else {
          document.getElementById('trackingError').style.display = 'block';
          const errorMsg = data.message || 'No payment found with this email.';
          document.getElementById('errorContent').innerHTML = '<h3>⚠️ No Record Found</h3><p>' + errorMsg + '</p>';
        }

        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      })
      .catch(err => {
        console.error('Error:', err);
        document.getElementById('trackingError').style.display = 'block';
        document.getElementById('errorContent').innerHTML = '<h3>⚠️ Error</h3><p>An error occurred while checking your status. Please try again.</p>';
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      });
  });

  // Subscription Expired Modal Functions
  function configureSubscriptionModal(error) {
    const modalTitle = document.getElementById('modalTitle');
    const modalHeading = document.getElementById('modalHeading');
    const modalDescription = document.getElementById('modalDescription');
    const statusBadge = document.getElementById('statusBadge');
    const actionText = document.getElementById('actionText');
    const actionButton = document.getElementById('actionButton');
    const actionButtonLabel = document.getElementById('actionButtonLabel');
    const closeBtn = document.querySelector('#subscriptionModal .modal-close');

    // Defaults for expired/paused cases
    modalTitle.textContent = '⏳ Subscription Expired';
    modalHeading.textContent = 'Your subscription has expired';
    modalDescription.textContent = (error && error.message) || 'Your account access is currently unavailable. Please renew your subscription to continue using the TRMS platform.';
    statusBadge.textContent = 'Subscription Expired';
    statusBadge.className = 'detail-value badge-expired';
    actionText.textContent = 'Renew your subscription now to regain access to your account and continue hiring.';
    actionButtonLabel.textContent = 'Renew Subscription';
    actionButton.onclick = redirectToSubscription;
    closeBtn.style.display = 'none';

    if (error && error.type === 'renewal_pending') {
      modalTitle.textContent = '⏳ Renewal Pending Verification';
      modalHeading.textContent = 'Renewal payment received';
      modalDescription.textContent = error.message || 'Your renewal payment is being reviewed. You will regain access once approved.';
      statusBadge.textContent = 'Verification Pending';
      statusBadge.className = 'detail-value badge-pending';
      actionText.textContent = 'We are verifying your renewal payment. You will regain access once approved.';
      actionButtonLabel.textContent = 'Okay, got it';
      actionButton.onclick = closeSubscriptionModal;
      closeBtn.style.display = 'flex';
    }
  }

  function openSubscriptionModal(error) {
    configureSubscriptionModal(error);
    document.getElementById('schoolNameDisplay').textContent = (error && error.schoolName) || 'Your School';
    document.getElementById('subscriptionModal').style.display = 'flex';
  }

  function closeSubscriptionModal() {
    document.getElementById('subscriptionModal').style.display = 'none';
  }

  function redirectToSubscription() {
    // Get the email from the login form
    const emailInput = document.getElementById('email');
    const email = emailInput ? emailInput.value : '';
    
    if (email) {
      window.location.href = '/renew-subscription?email=' + encodeURIComponent(email);
    } else {
      window.location.href = '/renew-subscription';
    }
  }

  // Check if subscription error exists on page load
  window.addEventListener('DOMContentLoaded', function() {
    const subscriptionErrorData = <%- JSON.stringify(subscriptionError || null) %>;
    if (subscriptionErrorData) {
      openSubscriptionModal(subscriptionErrorData);
    }
  });
</script>

<%- include('partials/footer') %>
