<%- include('partials/header') %>

<main class="school-login-layout">
  <div class="login-container">
    <!-- Left Side - Branding -->
    <div class="login-brand-section">
      <div class="brand-content">
        <div class="brand-logo">TRMS</div>
        <h1 class="brand-title">Teacher Recruitment System</h1>
        <p class="brand-subtitle">Manage your school's hiring process efficiently</p>
        
        <div class="brand-features">
          <div class="feature-item">
            <span class="feature-icon"><i class="fa-solid fa-check"></i></span>
            <span class="feature-text">Easy candidate management</span>
          </div>
          <div class="feature-item">
            <span class="feature-icon"><i class="fa-solid fa-check"></i></span>
            <span class="feature-text">Real-time application tracking</span>
          </div>
          <div class="feature-item">
            <span class="feature-icon"><i class="fa-solid fa-check"></i></span>
            <span class="feature-text">Secure credential access</span>
          </div>
          <div class="feature-item">
            <span class="feature-icon"><i class="fa-solid fa-check"></i></span>
            <span class="feature-text">Team collaboration tools</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Side - Login Form -->
    <div class="login-form-section">
      <div class="login-form-card">
        <div class="form-header">
          <h2>Welcome Back</h2>
          <p>Sign in to your school account</p>
        </div>

        <% if (error) { %>
          <div class="alert alert-error">
            <span class="alert-icon"><i class="fa-solid fa-triangle-exclamation"></i></span>
            <span><%= error.replace('email', 'user ID') %></span>
          </div>
        <% } %>

        <form method="POST" action="/school/login" class="login-form">
          <div class="form-group">
            <label for="loginId" class="form-label">User ID or Email</label>
            <input 
              id="loginId" 
              name="loginId" 
              type="text" 
              class="form-control login-input" 
              placeholder="Enter your User ID or Email"
              required
              autofocus
            >
          </div>

          <div class="form-group">
            <label for="password" class="form-label">Password</label>
            <input 
              id="password" 
              name="password" 
              type="password" 
              class="form-control login-input" 
              placeholder="Enter your password"
              required
            >
          </div>

          <div class="form-remember">
            <label class="checkbox-label">
              <input type="checkbox" name="remember" class="checkbox-input">
              <span>Remember me</span>
            </label>
          </div>

          <button type="submit" class="btn-login">
            <span>Sign In</span>
            <span class="btn-icon">→</span>
          </button>
        </form>

        <div class="form-footer">
          <button type="button" class="btn-contact" onclick="openCredentialsModal()">
            Don't have credentials?
          </button>
          <button type="button" class="btn-track" onclick="openTrackProgressModal()">
            Track Progress
          </button>
        </div>
      </div>

      <!-- Footer -->
      <div class="login-footer">
        <p class="footer-copyright">© 2024 Teacher Recruitment Management System. All rights reserved.</p>
      </div>
    </div>
  </div>

  <!-- Email Modal -->
  <div id="emailModal" class="modal" style="display: none;">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Get Started</h2>
        <button type="button" class="modal-close" onclick="closeCredentialsModal()">&times;</button>
      </div>
      <div class="modal-body">
        <p class="modal-subtitle">Enter your email to explore our subscription plans</p>
        <form id="emailForm" class="email-form">
          <div class="form-group">
            <label for="userEmail" class="form-label">Email Address</label>
            <input 
              id="userEmail" 
              name="email" 
              type="email" 
              class="form-control modal-input" 
              placeholder="your.email@gmail.com"
              required
              autofocus
            >
          </div>
          <button type="submit" class="btn-submit">Continue to Plans</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Track Progress Modal -->
  <div id="trackProgressModal" class="modal" style="display: none;">
    <div class="modal-content track-modal">
      <div class="modal-header">
        <h2>Track Your Progress</h2>
        <button type="button" class="modal-close" onclick="closeTrackProgressModal()">&times;</button>
      </div>
      <div class="modal-body">
        <p class="modal-subtitle">Enter the email you used during registration to check your verification status</p>
        
        <form id="trackForm" class="email-form">
          <div class="form-group">
            <label for="trackEmail" class="form-label">Email Address</label>
            <input 
              id="trackEmail" 
              name="email" 
              type="email" 
              class="form-control modal-input" 
              placeholder="your.email@gmail.com"
              required
              autofocus
            >
          </div>
          <button type="submit" class="btn-submit">Check Status</button>
        </form>

        <div id="trackingResult" class="tracking-result" style="display: none;">
          <div id="resultContent"></div>
        </div>

        <div id="trackingError" class="tracking-error" style="display: none;">
          <div id="errorContent"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Subscription Expired Modal -->
  <div id="subscriptionModal" class="modal" style="display: none;">
    <div class="modal-content subscription-modal">
      <div class="modal-header">
          <h2 id="modalTitle"><i class="fa-solid fa-hourglass-half"></i> Subscription Expired</h2>
          <button type="button" class="modal-close" onclick="closeSubscriptionModal()" style="display: none;">&times;</button>
        </div>
      <div class="modal-body">
          <div class="subscription-alert">
          <div class="alert-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
          <div class="alert-message">
            <h3 id="modalHeading">Your subscription has expired</h3>
            <p id="modalDescription">Your account access is currently unavailable. Please renew your subscription to continue using the TRMS platform.</p>
          </div>
        </div>
        
        <div class="subscription-details">
          <div class="detail-item">
            <span class="detail-label">School Name:</span>
            <span class="detail-value" id="schoolNameDisplay"></span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Status:</span>
            <span class="detail-value badge-expired" id="statusBadge">Subscription Expired</span>
          </div>
        </div>

        <div class="subscription-action">
          <p class="action-text" id="actionText">Renew your subscription now to regain access to your account and continue hiring.</p>
          <button type="button" class="btn btn-renew" id="actionButton" onclick="redirectToSubscription()">
            <span id="actionButtonLabel">Renew Subscription</span>
            <span class="btn-arrow">→</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</main>

