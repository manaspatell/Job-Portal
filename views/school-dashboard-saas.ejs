<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    height: 100%;
    overflow-x: hidden;
  }

  body {
    background: #f8fafc;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
  }

  /* Sidebar Navigation */
  .saas-container {
    display: flex;
    min-height: 100vh;
  }

  .saas-sidebar {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: white;
    padding: 24px 0;
    width: 260px;
    min-width: 260px;
    height: 100vh;
    position: sticky;
    top: 0;
    overflow-y: auto;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }

  .sidebar-brand {
    padding: 0 20px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 24px;
  }

  .sidebar-brand-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .sidebar-brand-text h3 {
    font-size: 16px;
    font-weight: 700;
    margin: 0 0 4px 0;
  }

  .sidebar-brand-text p {
    font-size: 12px;
    opacity: 0.7;
    margin: 0;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sidebar-nav-item {
    padding: 12px 20px;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: all 0.2s;
    border-left: 3px solid transparent;
    cursor: pointer;
  }

  .sidebar-nav-item:hover {
    background: rgba(255, 255, 255, 0.05);
    color: white;
  }

  .sidebar-nav-item.active {
    background: rgba(59, 130, 246, 0.2);
    color: #3b82f6;
    border-left-color: #3b82f6;
  }

  .sidebar-nav-icon {
    font-size: 18px;
    width: 20px;
    text-align: center;
  }

  .sidebar-footer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.2);
  }

  .user-profile {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3b82f6, #1d4ed8);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 600;
  }

  .user-info h4 {
    font-size: 12px;
    font-weight: 600;
    margin: 0;
  }

  .user-info p {
    font-size: 11px;
    opacity: 0.6;
    margin: 0;
  }

  .logout-btn {
    position: absolute;
    bottom: 16px;
    right: 16px;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .logout-btn:hover {
    background: rgba(255, 59, 48, 0.3);
  }

  /* Main Content */
  .saas-main {
    flex: 1;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .saas-topbar {
    background: white;
    border-bottom: 1px solid #e2e8f0;
    padding: 16px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .topbar-title h1 {
    margin: 0;
    font-size: 20px;
    font-weight: 700;
    color: #0f172a;
  }

  .topbar-actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #f1f5f9;
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
  }

  .search-box input {
    background: none;
    border: none;
    outline: none;
    font-size: 13px;
    width: 200px;
  }

  .action-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    transition: all 0.2s;
  }

  .action-btn:hover {
    background: #e2e8f0;
  }

  .saas-content {
    padding: 32px;
    max-width: 1600px;
    margin: 0 auto;
  }

  /* Hero Section */
  .hero-section {
    background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
    border-radius: 16px;
    padding: 32px;
    color: white;
    margin-bottom: 28px;
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 400px;
    height: 400px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-content h2 {
    font-size: 28px;
    font-weight: 700;
    margin: 0 0 8px 0;
  }

  .hero-content p {
    font-size: 14px;
    opacity: 0.9;
    margin: 0 0 20px 0;
    max-width: 400px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
  }

  .btn {
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-primary {
    background: white;
    color: #3b82f6;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.2);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  /* Stats Grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }

  .stat-card {
    background: white;
    border-radius: 12px;
    padding: 24px;
    border: 1px solid #e2e8f0;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .stat-card:hover {
    border-color: #cbd5e0;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    transform: translateY(-4px);
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--stat-color);
  }

  .stat-card.blue { --stat-color: #3b82f6; }
  .stat-card.green { --stat-color: #10b981; }
  .stat-card.orange { --stat-color: #f59e0b; }
  .stat-card.red { --stat-color: #ef4444; }
  .stat-card.purple { --stat-color: #8b5cf6; }

  .stat-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  .stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    background: var(--stat-bg);
    color: var(--stat-color);
  }

  .stat-card.blue .stat-icon { --stat-bg: #dbeafe; --stat-color: #3b82f6; }
  .stat-card.green .stat-icon { --stat-bg: #dcfce7; --stat-color: #10b981; }
  .stat-card.orange .stat-icon { --stat-bg: #fef3c7; --stat-color: #f59e0b; }
  .stat-card.red .stat-icon { --stat-bg: #fee2e2; --stat-color: #ef4444; }
  .stat-card.purple .stat-icon { --stat-bg: #ede9fe; --stat-color: #8b5cf6; }

  .stat-label {
    font-size: 12px;
    color: #64748b;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }

  .stat-value {
    font-size: 32px;
    font-weight: 700;
    color: #0f172a;
    margin: 0;
    line-height: 1;
  }

  .stat-change {
    font-size: 12px;
    margin-top: 8px;
  }

  .stat-change.positive {
    color: #10b981;
  }

  .stat-change.negative {
    color: #ef4444;
  }

  /* Recent Activity */
  .activity-section {
    background: white;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    padding: 24px;
    margin-bottom: 32px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }

  .section-header h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 700;
    color: #0f172a;
  }

  .view-all {
    font-size: 13px;
    color: #3b82f6;
    text-decoration: none;
    font-weight: 600;
  }

  .activity-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .activity-item {
    display: flex;
    gap: 12px;
    padding-bottom: 16px;
    border-bottom: 1px solid #e2e8f0;
  }

  .activity-item:last-child {
    border-bottom: none;
  }

  .activity-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #e0e7ff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }

  .activity-content h4 {
    margin: 0 0 4px 0;
    font-size: 13px;
    font-weight: 600;
    color: #0f172a;
  }

  .activity-content p {
    margin: 0;
    font-size: 12px;
    color: #64748b;
  }

  .activity-time {
    margin-left: auto;
    font-size: 12px;
    color: #94a3b8;
    text-align: right;
  }

  /* Two Column Layout */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 24px;
    margin-bottom: 32px;
  }

  @media (max-width: 1280px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 1024px) {
    .saas-container {
      flex-direction: column;
    }

    .saas-sidebar {
      display: none;
    }

    .saas-main {
      width: 100%;
    }

    .content-grid {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .saas-content {
      padding: 20px;
    }

    .hero-section {
      padding: 24px;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .saas-topbar {
      padding: 12px 20px;
    }

    .search-box {
      display: none;
    }
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 40px 20px;
  }

  .empty-state-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .empty-state h3 {
    margin: 0 0 8px 0;
    font-size: 16px;
    font-weight: 600;
    color: #0f172a;
  }

  .empty-state p {
    margin: 0;
    font-size: 13px;
    color: #64748b;
  }
  </style>
</head>
<body>

<div class="saas-container">
  <!-- Sidebar -->
  <aside class="saas-sidebar">
    <div class="sidebar-brand">

      <div class="sidebar-brand-text">
        <h3>TRMS</h3>
        <p>Teacher Recruitment</p>
      </div>
    </div>

    <nav class="sidebar-nav">
      <a href="/school/dashboard" class="sidebar-nav-item active">

        <span>Dashboard</span>
      </a>
      <a href="/school/applicants" class="sidebar-nav-item">

        <span>Applicants</span>
      </a>
      <a href="#" class="sidebar-nav-item">

        <span>Jobs</span>
      </a>
      <a href="#" class="sidebar-nav-item">

        <span>Reports</span>
      </a>
      <a href="#" class="sidebar-nav-item">

        <span>Settings</span>
      </a>
      <a href="#" class="sidebar-nav-item">

        <span>Help & Support</span>
      </a>
    </nav>

    <div class="sidebar-footer">
      <div class="user-profile">

        <div class="user-info">
          <h4><%= schoolName || location %></h4>
          <p>School Account</p>
        </div>
      </div>
      <form method="POST" action="/school/logout" style="display: inline;">
        <button type="submit" class="logout-btn" title="Logout">Logout</button>
      </form>
    </div>
  </aside>

  <!-- Main Content -->
  <div class="saas-main">
    <!-- Top Bar -->
    <div class="saas-topbar">
      <div class="topbar-title">
        <h1>Welcome back, <%= schoolName || location %>!</h1>
      </div>
      <div class="topbar-actions">
        <div class="search-box">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search...">
        </div>
        
        <button class="action-btn"><i class="fa-solid fa-star"></i></button>
      </div>
    </div>

    <!-- Content -->
    <div class="saas-content">
      <!-- Hero Section -->
      <div class="hero-section">
        <div class="hero-content">
          <h2><i class="fa-solid fa-chart-line"></i> Supercharge Your Hiring</h2>
          <p>Manage applicants efficiently, track progress in real-time, and build the perfect team for your school.</p>
          <div class="hero-actions">
            <a href="/school/applicants" class="btn btn-primary">View Applicants</a>
            <button class="btn btn-secondary">Learn More</button>
          </div>
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="stats-grid">
        <div class="stat-card blue">
          <div class="stat-header">
            <div>
              <div class="stat-label">Total Applicants</div>
              <div class="stat-value"><%= stats.total || 0 %></div>
              <div class="stat-change positive">↑ 12% from last month</div>
            </div>

          </div>
        </div>

        <div class="stat-card green">
          <div class="stat-header">
            <div>
              <div class="stat-label">Shortlisted</div>
              <div class="stat-value"><%= stats.byStatus?.shortlisted || 0 %></div>
              <div class="stat-change positive">↑ 8% improvement</div>
            </div>

          </div>
        </div>

        <div class="stat-card orange">
          <div class="stat-header">
            <div>
              <div class="stat-label">Pending Review</div>
              <div class="stat-value"><%= stats.byStatus?.pending || 0 %></div>
              <div class="stat-change negative">Action needed</div>
            </div>

          </div>
        </div>

        <div class="stat-card purple">
          <div class="stat-header">
            <div>
              <div class="stat-label">Avg Expected Salary</div>
              <div class="stat-value">₹<%= stats.avgSalary ? (stats.avgSalary / 1000).toFixed(1) + 'K' : '0' %></div>
              <div class="stat-change">Budget aligned</div>
            </div>

          </div>
        </div>
      </div>

      <!-- Content Grid -->
      <div class="content-grid">
        <!-- Recent Activity -->
        <div class="activity-section">
          <div class="section-header">
            <h3>Recent Applications</h3>
            <a href="/school/applicants" class="view-all">View All →</a>
          </div>
          <div class="activity-list">
            <% if (!recentApplicants || recentApplicants.length === 0) { %>
              <div class="empty-state">

                <h3>No recent applications</h3>
                <p>When new applicants submit their profiles, they'll appear here.</p>
              </div>
            <% } else { %>
              <% recentApplicants.slice(0, 5).forEach(app => { %>
                <div class="activity-item">
                  <div class="activity-avatar"><%- app.name ? app.name.charAt(0).toUpperCase() : '<i class="fa-solid fa-user"></i>' %></div>
                  <div class="activity-content" style="flex: 1;">
                    <h4><%= app.name || 'Unknown' %></h4>
                    <p><%= app.highestQualification || 'N/A' %> • <%= app.preferredLocation || 'N/A' %></p>
                  </div>
                  <div class="activity-time">
                    <%= new Date(app.createdAt || Date.now()).toLocaleDateString('en-IN', {month: 'short', day: 'numeric'}) %>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <!-- Quick Actions -->
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <div class="activity-section">
            <h3 style="margin: 0 0 16px 0; font-size: 14px; font-weight: 600;">Quick Actions</h3>
            <div style="display: flex; flex-direction: column; gap: 10px;">
              <a href="/school/applicants" class="btn btn-primary" style="justify-content: center; padding: 12px;">View All Applicants</a>
              <button class="btn btn-secondary" style="justify-content: center; padding: 12px; background: #f1f5f9; color: #0f172a; border: 1px solid #e2e8f0;">Export Report</button>
              <button class="btn btn-secondary" style="justify-content: center; padding: 12px; background: #f1f5f9; color: #0f172a; border: 1px solid #e2e8f0;">Invite Candidates</button>
            </div>
          </div>

          <div class="activity-section">
            <h3 style="margin: 0 0 16px 0; font-size: 14px; font-weight: 600;">Your Plan</h3>
            <div style="display: flex; flex-direction: column; gap: 12px;">
              <div style="display: flex; justify-content: space-between;">
                <span style="font-size: 13px; color: #64748b;">Active Users</span>
                <span style="font-size: 13px; font-weight: 600; color: #0f172a;">3/5</span>
              </div>
              <div style="height: 8px; background: #e2e8f0; border-radius: 4px; overflow: hidden;">
                <div style="height: 100%; width: 60%; background: #3b82f6; border-radius: 4px;"></div>
              </div>
              <p style="margin: 0; font-size: 12px; color: #64748b;">Upgrade to add more users</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

</body>
</html>
