        <div class="saas-form-row">
          <div class="saas-form-group">
            <label for="highestQualification">Highest Qualification <span class="required">*</span></label>
            <select id="highestQualification" name="highestQualification" required class="form-control">
              <option value="">Select your highest qualification</option>
              <option value="B.Ed">B.Ed (Bachelor of Education)</option>
              <option value="M.Ed">M.Ed (Master of Education)</option>
              <option value="B.A. B.Ed">B.A. B.Ed (Integrated)</option>
              <option value="B.Sc. B.Ed">B.Sc. B.Ed (Integrated)</option>
              <option value="D.El.Ed">D.El.Ed (Diploma in Elementary Education)</option>
              <option value="Ph.D.">Ph.D. (Doctorate)</option>
              <option value="B.A.">B.A. (Bachelor of Arts)</option>
              <option value="B.Sc.">B.Sc. (Bachelor of Science)</option>
              <option value="B.Com.">B.Com. (Bachelor of Commerce)</option>
              <option value="M.A.">M.A. (Master of Arts)</option>
              <option value="M.Sc.">M.Sc. (Master of Science)</option>
              <option value="M.Com.">M.Com. (Master of Commerce)</option>
              <option value="B.Tech/B.E.">B.Tech/B.E. (Engineering)</option>
              <option value="M.Tech/M.E.">M.Tech/M.E. (Engineering)</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="saas-form-group">
            <label for="collegeName">College/University Name <span class="required">*</span></label>
            <input type="text" id="collegeName" name="collegeName" required placeholder="Enter your college/university name" class="form-control">
          </div>
        </div>
        <div class="saas-form-row">
          <div class="saas-form-group">
            <label for="collegeTier">College Tier <span class="required">*</span></label>
            <select id="collegeTier" name="collegeTier" required class="form-control">
              <option value="">Select college tier</option>
              <option value="Tier 1">Tier 1 (IIT, NIT, Central Universities)</option>
              <option value="Tier 2">Tier 2 (State Universities, Private Top Institutions)</option>
              <option value="Tier 3">Tier 3 (Other Universities)</option>
            </select>
          </div>
          <div class="saas-form-group">
            <label for="skills">Skills & Subjects You Can Teach <span class="required">*</span></label>
            <textarea id="skills" name="skills" required placeholder="E.g., Mathematics, Science, English, Computer Science, Classroom Management, Online Teaching, etc." rows="4" class="form-control"></textarea>
            <small class="form-text">List subjects, teaching methodologies, certifications (CTET/TET), technical skills, etc.</small>
          </div>
        </div>
        <div class="saas-form-row">
          <div class="saas-form-group">
            <label for="expectedSalary">Expected Salary <span class="required">*</span></label>
            <input type="number" id="expectedSalary" name="expectedSalary" required placeholder="Enter expected salary" class="form-control">
          </div>
