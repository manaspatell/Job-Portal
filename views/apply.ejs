  <style>
    .saas-modal-overlay {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(30, 34, 90, 0.18);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      min-width: 100vw;
    }
    .saas-modal-card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.13);
      padding: 2rem 2.2rem 1.5rem 2.2rem;
      max-width: 350px;
      width: 98vw;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      animation: saasModalPop 0.18s cubic-bezier(.4,1.6,.6,1) 1;
    }
    .saas-modal-title {
      font-size: 1.3rem;
      font-weight: 700;
      color: #1a237e;
      margin-bottom: 0.5rem;
    }
    .saas-modal-desc {
      color: #333;
      font-size: 1rem;
      margin-bottom: 0.7rem;
    }
    @keyframes saasModalPop {
      0% { transform: scale(0.85); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }
  </style>
  </section>
</main>

<script>
  function togglePaidBenefits() {
    var paid = document.getElementById('isPaid').checked;
    document.getElementById('paidBenefits').style.display = paid ? 'block' : 'none';
  }
</script>

<style>
  .saas-apply-container {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
    background: #f7fafd;
    padding: 2rem 0;
  }
  .saas-apply-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    padding: 2rem 2rem 1.5rem 2rem;
    max-width: 700px;
    width: 100%;
    margin: 2rem 1rem;
  }
  .saas-apply-title {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: #1a237e;
  }
  .saas-apply-form {
    width: 100%;
  }
  .saas-form-section {
    margin-bottom: 2rem;
  }
  .saas-form-section h3 {
    font-size: 1.2rem;
    color: #1976d2;
    margin-bottom: 1rem;
    font-weight: 600;
  }
  .saas-form-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }
  .saas-form-group {
    flex: 1 1 220px;
    display: flex;
    flex-direction: column;
  }
  .saas-form-group label {
    font-weight: 500;
    margin-bottom: 0.4rem;
    color: #333;
  }
  .saas-form-group input,
  .saas-form-group select,
  .saas-form-group textarea {
    border: 1px solid #cfd8dc;
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    font-size: 1rem;
    background: #f9f9fb;
    margin-bottom: 0.2rem;
    transition: border 0.2s;
  }
  .saas-form-group input:focus,
  .saas-form-group select:focus,
  .saas-form-group textarea:focus {
    border: 1.5px solid #1976d2;
    outline: none;
    background: #fff;
  }
  .saas-form-group .form-text {
    font-size: 0.85rem;
    color: #607d8b;
  }
  .saas-form-actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
    margin-top: 1.5rem;
  }
  .btn.btn-primary {
    background: #1976d2;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 0.7rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn.btn-primary:hover {
    background: #0d47a1;
  }
  .btn.btn-secondary {
    background: #e3eafc;
    color: #1976d2;
    border: none;
    border-radius: 6px;
    padding: 0.7rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn.btn-secondary:hover {
    background: #bbdefb;
  }
  @media (max-width: 900px) {
    .saas-apply-card {
      max-width: 98vw;
      padding: 1.2rem 0.5rem 1rem 0.5rem;
    }
    .saas-form-row {
      gap: 1rem;
    }
  }
  @media (max-width: 600px) {
    .saas-apply-container {
      padding: 0.5rem 0;
    }
    .saas-apply-card {
      margin: 0.5rem 0.1rem;
      padding: 0.7rem 0.2rem 0.7rem 0.2rem;
      border-radius: 8px;
    }
    .saas-form-row {
      flex-direction: column;
      gap: 0.5rem;
    }
    .saas-form-group {
      min-width: 0;
    }
    .saas-form-section {
      margin-bottom: 1.2rem;
    }
    .saas-form-actions {
      flex-direction: column;
      gap: 0.5rem;
      align-items: stretch;
    }
  }
</style>

<%- include('partials/footer') %>
