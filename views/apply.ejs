          "Delhi": ["New Delhi", "Delhi", "Dwarka", "Rohini", "Karol Bagh", "Saket", "Vasant Kunj", "Janakpuri", "Laxmi Nagar", "Pitampura"],
          "Jammu and Kashmir": ["Srinagar", "Jammu", "Anantnag", "Baramulla", "Kathua", "Udhampur", "Sopore", "Rajouri", "Poonch", "Pulwama"],
