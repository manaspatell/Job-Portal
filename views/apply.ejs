          </div>
        </div>
      </div>
      <div class="saas-form-section">
        <h3>CV Upload</h3>
        <div class="saas-form-row">
          <div class="saas-form-group">
            <label for="cv">CV (PDF, DOC, DOCX only) <span class="required">*</span></label>
            <input type="file" id="cv" name="cv" accept=".pdf,.doc,.docx" required class="form-control">
            <small>Max file size: 5MB</small>
          </div>
        </div>
      </div>

      <div class="saas-form-section">
        <h3>Application Type</h3>
        <div class="saas-form-row">
          <div class="saas-form-group">
            <label><input type="checkbox" id="isPaid" name="isPaid" value="true" onchange="togglePaidBenefits()"> Apply as Paid (Premium)</label>
          </div>
        </div>
        <div id="paidBenefits" class="saas-form-group" style="display:none; margin-top:0.5rem;">
          <div class="saas-paid-benefits">
            <strong>Paid Application Benefits:</strong>
            <ul style="margin:0.5rem 0 0 1.2rem;">
              <li>Priority listing for recruiters</li>
              <li>Direct contact from schools</li>
              <li>Profile highlighted as premium</li>
              <li>Access to exclusive job postings</li>
              <li>Faster application review</li>
            </ul>
          </div>
        </div>
