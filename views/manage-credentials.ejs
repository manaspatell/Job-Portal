<script>
  function openEditModal(id, name, userId, location, genderFilter, subscriptionTier) {
    document.getElementById('edit-name').value = name;
    document.getElementById('edit-userId').value = userId;
    document.getElementById('edit-location').value = location;
    document.getElementById('edit-genderFilter').value = genderFilter || 'all';
    document.getElementById('edit-password').value = '';
    
    // Set subscription tier radio button
    const tierValue = subscriptionTier || 'none';
    const tierRadio = document.querySelector(`input[name="subscriptionTier"][value="${tierValue}"]`);
    if (tierRadio) {
      tierRadio.checked = true;
    }
    
    document.getElementById('editForm').action = '/admin/credentials/edit/' + id;
    document.getElementById('editModal').style.display = 'flex';
  }

  function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
  }

  function confirmDelete(id, name) {
    document.getElementById('delete-school-name').textContent = name;
    document.getElementById('deleteForm').action = '/admin/credentials/delete/' + id;
    document.getElementById('deleteModal').style.display = 'flex';
  }

  function closeDeleteModal() {
    document.getElementById('deleteModal').style.display = 'none';
  }

  function toggleKebab(event) {
    event.stopPropagation();
    const dropdown = event.target.nextElementSibling;
    document.querySelectorAll('.kebab-dropdown.show').forEach(d => {
      if (d !== dropdown) d.classList.remove('show');
    });
    dropdown.classList.toggle('show');
  }

  document.addEventListener('click', () => {
    document.querySelectorAll('.kebab-dropdown.show').forEach(d => d.classList.remove('show'));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeEditModal();
      closeDeleteModal();
      document.querySelectorAll('.kebab-dropdown.show').forEach(d => d.classList.remove('show'));
    }
  });

  window.onclick = function(event) {
    const editModal = document.getElementById('editModal');
    const deleteModal = document.getElementById('deleteModal');
    if (event.target === editModal) closeEditModal();
    if (event.target === deleteModal) closeDeleteModal();
  };

  // Credential filters: client-side quick filter + clear
  (function(){
    const locationFilter = document.getElementById('locationFilter');
    const searchInput = document.getElementById('searchSchools');
    const tbody = document.querySelector('.schools-table tbody');

    function applyCredentialFilters() {
      if (!tbody) return;
      const loc = locationFilter ? locationFilter.value.trim().toLowerCase() : '';
      const term = searchInput ? searchInput.value.trim().toLowerCase() : '';
      tbody.querySelectorAll('tr').forEach(tr => {
        const name = (tr.querySelector('.col-name') && tr.querySelector('.col-name').innerText) || '';
        const userId = (tr.querySelector('.col-email') && tr.querySelector('.col-email').innerText) || '';
        const locationText = (tr.querySelector('.col-location') && tr.querySelector('.col-location').innerText) || '';
        const matchesLoc = !loc || locationText.toLowerCase().indexOf(loc) !== -1;
        const matchesTerm = !term || name.toLowerCase().indexOf(term) !== -1 || userId.toLowerCase().indexOf(term) !== -1;
        if (matchesLoc && matchesTerm) tr.style.display = '';
        else tr.style.display = 'none';
      });
    }

    function clearCredentialFilters() {
      if (locationFilter) locationFilter.value = '';
      if (searchInput) searchInput.value = '';
      applyCredentialFilters();
    }

    if (locationFilter) locationFilter.addEventListener('change', applyCredentialFilters);
    if (searchInput) searchInput.addEventListener('input', function(){ applyCredentialFilters(); });
    // expose helper for inline use
    window.clearCredentialFilters = clearCredentialFilters;
  })();
</script>

