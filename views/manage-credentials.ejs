<%- include('partials/header') %>
<link rel="stylesheet" href="/css/admin-theme.css">

<main class="admin-theme">
  <div class="ad-shell">
    <%- include('partials/admin-sidebar', { activePage: 'schools' }) %>

    <section class="ad-main">
      <header class="ad-topbar">
        <div>
          <div class="ad-page-title">School Credentials</div>
          <div class="ad-page-subtitle">Manage location-based school portal access</div>
        </div>
        <div class="ad-topbar-actions">
          <div class="ad-avatar" title="Admin"><img src="/images/icon/admin.png" alt="Admin"/></div>
        </div>
      </header>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="ad-alert ad-alert-error">
        <strong>Error:</strong> <%= error %>
      </div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="ad-alert ad-alert-success">
        <strong>Success:</strong> <%= success %>
      </div>
    <% } %>

    <!-- Controls Bar -->
    <div class="ad-card">
        <div class="ad-card-head" style="display:flex;justify-content:space-between;align-items:center;gap:10px;">
        <div>
          <div class="ad-card-title">Controls</div>
          <div class="ad-card-sub">Filter and manage school credentials</div>
        </div>
        <a href="/admin/credentials/create" class="ad-btn ad-btn-primary"><i class="fa-solid fa-plus" style="margin-right:6px"></i> Add School</a>
      </div>
      <div style="padding: 12px 14px;">
        <div class="ad-form-row">
          <select class="ad-select" id="locationFilter">
          <option value="">All Locations</option>
          <% if (locations && locations.length > 0) { %>
            <% locations.forEach(loc => { %>
              <option value="<%= loc %>"><%= loc %></option>
            <% }); %>
          <% } %>
        </select>
        <input type="text" class="ad-input" id="searchSchools" placeholder="Search schools or user ID..." />
        <button type="button" class="ad-btn" id="clearCredentialFilters" onclick="clearCredentialFilters()" style="margin-left:6px;">Clear</button>
        </div>
      </div>
    </div>

    <!-- Schools Table -->
    <% if (schools && schools.length > 0) { %>
      <div class="ad-card">
        <div class="ad-table-wrap">
        <table class="ad-table schools-table">
          <thead>
            <tr>
              <th>School Name</th>
              <th>User ID</th>
              <th>Location</th>
              <th>Status</th>
              <th>Subscription</th>
              <th>Created</th>
              <th class="actions-col">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% schools.forEach(school => { 
              const now = new Date();
              const isExpired = school.expiryDate && now > school.expiryDate;
              const daysRemaining = school.expiryDate ? Math.ceil((school.expiryDate - now) / (1000 * 60 * 60 * 24)) : null;
            %>
              <tr class="<%= isExpired ? 'row-expired' : '' %>">
                <td class="col-name">
                  <div class="school-name"><%= school.name %></div>
                  <% if (school.genderFilter && school.genderFilter !== 'all') { %>
                    <div class="school-meta"><%= school.genderFilter === 'male' ? 'Male only' : 'Female only' %></div>
                  <% } %>
                </td>
                <td class="col-email">
                  <code><%= school.userId %></code>
                </td>
                <td class="col-location">
                  <span class="location-pill"><%= school.location %></span>
                </td>
                <td class="col-status">
                  <% 
                    // Check if school has no subscription
                    const hasNoSubscription = !school.subscription || !school.subscription.tier || school.subscription.tier === 'none';
                  %>
                  <% if (hasNoSubscription) { %>
                    <span class="status-badge status-paused">Paused (No Subscription)</span>
                  <% } else if (isExpired) { %>
                    <span class="status-badge status-expired">Expired</span>
                  <% } else if (school.status === 'active') { %>
                    <span class="status-badge status-active">Active</span>
                  <% } else { %>
                    <span class="status-badge status-paused">Paused</span>
                  <% } %>
                </td>
                <td class="col-subscription">
                  <% if (school.subscription && school.subscription.tier && school.subscription.tier !== 'none') { %>
                    <div class="subscription-pill">
                      <span class="subscription-badge <%= school.subscription.tier %>"><%= school.subscription.tier.toUpperCase() %></span>
                      <% 
                        const now = new Date();
                        const subEndDate = school.subscription.endDate ? new Date(school.subscription.endDate) : null;
                        const subDaysLeft = subEndDate ? Math.ceil((subEndDate - now) / (1000 * 60 * 60 * 24)) : null;
                      %>
                      <% if (subEndDate && now > subEndDate) { %>
                        <small class="sub-status sub-expired">Expired</small>
                      <% } else if (subDaysLeft && subDaysLeft <= 7) { %>
                        <small class="sub-status sub-critical"><%= subDaysLeft %>d left</small>
                      <% } else if (subDaysLeft) { %>
                        <small class="sub-status sub-active"><%= subDaysLeft %>d left</small>
                      <% } %>
                    </div>
                  <% } else { %>
                    <span class="sub-none">No subscription</span>
                  <% } %>
                </td>
                <td class="col-created">
                  <small><%= new Date(school.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></small>
                </td>
                <td class="col-actions">
                  <div class="dropdown">
                    <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton-<%= school._id %>" data-bs-toggle="dropdown" aria-expanded="false">
                      Actions
                    </button>
                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton-<%= school._id %>">
                      <li>
                        <button class="dropdown-item" type="button" onclick="openEditModal('<%= school._id %>', '<%= school.name %>', '<%= school.email %>', '<%= school.location %>', '<%= school.genderFilter || 'all' %>', '<%= school.subscription?.tier || 'none' %>')">Edit</button>
                      </li>
                      <% if (!school.subscription || !school.subscription.tier || school.subscription.tier === 'none') { %>
                        <li>
                          <a class="dropdown-item" href="/admin/credentials/subscribe/<%= school._id %>">Activate Subscription</a>
                        </li>
                      <% } else if (school.subscription && school.subscription.endDate && new Date() > new Date(school.subscription.endDate)) { %>
                        <li>
                          <a class="dropdown-item" href="/admin/credentials/renew/<%= school._id %>">Renew Subscription</a>
                        </li>
                      <% } else if (school.status === 'active') { %>
                        <li>
                          <form method="POST" action="/admin/credentials/toggle/<%= school._id %>" style="display: contents;">
                            <button type="submit" class="dropdown-item">Pause Subscription</button>
                          </form>
                        </li>
                      <% } else { %>
                        <li>
                          <form method="POST" action="/admin/credentials/toggle/<%= school._id %>" style="display: contents;">
                            <button type="submit" class="dropdown-item">Activate Subscription</button>
                          </form>
                        </li>
                      <% } %>
                      <li>
                        <button class="dropdown-item text-danger" type="button" onclick="confirmDelete('<%= school._id %>', '<%= school.name %>')">Delete</button>
                      </li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      </div>
    <% } else { %>
      <div class="ad-card">
        <div style="padding: 28px; text-align:center;">
          <div style="font-size: 46px; margin-bottom: 10px;"><i class="fa-solid fa-school"></i></div>
          <div class="ad-card-title" style="font-size: 16px;">No School Credentials</div>
          <div class="ad-card-sub" style="margin-top:6px;">Create your first school credential to provide location-based access</div>
          <div style="margin-top: 14px;">
            <a href="/admin/credentials/create" class="ad-btn ad-btn-primary">+ Add School</a>
          </div>
        </div>
      </div>
    <% } %>
    </section>
  </div>
</main>

<!-- Edit Modal -->
<div id="editModal" class="modal" style="display: none;">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Edit School Credential</h3>
      <button class="modal-close" onclick="closeEditModal()">&times;</button>
    </div>
    <form id="editForm" method="POST" action="" class="modal-body">
      <div class="form-group">
        <label for="edit-name">School Name</label>
        <input type="text" id="edit-name" name="name" class="form-control" required>
      </div>
      <div class="form-group">
        <label for="edit-userId">User ID</label>
        <input type="number" id="edit-userId" name="userId" class="form-control" required>
      </div>
      <div class="form-group">
        <label for="edit-location">Location</label>
        <select id="edit-location" name="location" class="form-control" required>
          <option value="">-- Select Location --</option>
          <% if (locations && locations.length > 0) { %>
            <% locations.forEach(loc => { %>
              <option value="<%= loc %>"><%= loc %></option>
            <% }); %>
          <% } %>
        </select>
      </div>
      <div class="form-group">
        <label for="edit-genderFilter">Gender Filter</label>
        <select id="edit-genderFilter" name="genderFilter" class="form-control" required>
          <option value="all">All Genders</option>
          <option value="male">Male Only</option>
          <option value="female">Female Only</option>
        </select>
      </div>

      <!-- Subscription Section in Edit Modal -->
      <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #e7e9f0;">
        <label style="font-weight: 600; color: #374151; font-size: 12px; display: block; margin-bottom: 12px;">Subscription Plan</label>
        <div class="subscription-options-compact">
          <label class="subscription-option">
            <input type="radio" name="subscriptionTier" value="none" class="subscription-radio">
            <div class="option-label">
              <div class="option-name">No Subscription</div>
              <div class="option-detail">Free</div>
            </div>
          </label>
          <label class="subscription-option">
            <input type="radio" name="subscriptionTier" value="silver" class="subscription-radio">
            <div class="option-label">
              <div class="option-name">Silver</div>
              <div class="option-detail">30 days</div>
            </div>
          </label>
          <label class="subscription-option">
            <input type="radio" name="subscriptionTier" value="gold" class="subscription-radio">
            <div class="option-label">
              <div class="option-name">Gold</div>
              <div class="option-detail">6 months</div>
            </div>
          </label>
          <label class="subscription-option">
            <input type="radio" name="subscriptionTier" value="diamond" class="subscription-radio">
            <div class="option-label">
              <div class="option-name">Diamond</div>
              <div class="option-detail">1 year</div>
            </div>
          </label>
        </div>
      </div>

      <div class="form-group">
        <label for="edit-password">New Password (optional)</label>
        <input type="password" id="edit-password" name="password" class="form-control" placeholder="Leave blank to keep current">
      </div>
      <div class="modal-footer">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Cancel</button>
      </div>
    </form>
  </div>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="modal" style="display: none;">
  <div class="modal-content modal-compact">
    <div class="modal-header modal-danger">
      <h3>Delete School Credential</h3>
      <button class="modal-close" onclick="closeDeleteModal()">&times;</button>
    </div>
    <div class="modal-body">
      <p>Are you sure you want to delete <strong id="delete-school-name"></strong>? This action cannot be undone.</p>
      <form id="deleteForm" method="POST" action="" style="display: flex; gap: 12px; margin-top: 24px;">
        <button type="submit" class="btn btn-danger" style="flex: 1;">Delete</button>
        <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()" style="flex: 1;">Cancel</button>
      </form>
    </div>
  </div>
</div>

