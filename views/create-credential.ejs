<%- include('partials/header') %>
<link rel="stylesheet" href="/css/admin-theme.css">

<main class="admin-theme">
  <div class="ad-shell">
    <%- include('partials/admin-sidebar', { activePage: 'schools' }) %>
    <section class="ad-main">
      <header class="ad-topbar">
        <div>
          <div class="ad-page-title">Create School Credential</div>
          <div class="ad-page-subtitle">Generate location-based portal access for a new school</div>
        </div>

        <div class="ad-topbar-actions">
          <a href="/admin/credentials" class="ad-btn">Back to Credentials</a>
          <div class="ad-avatar" title="Admin"><img src="/images/icon/admin.png" alt="Admin"/></div>
        </div>
      </header>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error">
        <strong>Error:</strong> <%= error %>
      </div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success">
        <strong>Success:</strong> <%= success %>
      </div>
    <% } %>

    <!-- Form Card -->
    <div class="form-card">
      <div class="form-card-header">
        <h2 class="form-card-title">School Information</h2>
        <p class="form-card-desc">Configure school credentials and access permissions</p>
      </div>

      <form method="POST" action="/admin/credentials/create" class="saas-form">
        <div class="form-row">
          <div class="form-group">
            <label for="name">School Name <span class="required">*</span></label>
            <input id="name" name="name" type="text" class="form-control" placeholder="e.g., Springfield High School" required value="<%= typeof autofill !== 'undefined' && autofill.name ? autofill.name : '' %>">
          </div>
          
          <div class="form-group">
            <label for="userId">User ID <span class="required">*</span></label>
            <input id="userId" name="userId" type="number" class="form-control" placeholder="Enter unique User ID" required value="<%= typeof autofill !== 'undefined' && autofill.userId ? autofill.userId : '' %>">
          </div>
          <div class="form-group">
            <label for="email">Email <span class="required">*</span></label>
            <input id="email" name="email" type="email" class="form-control" placeholder="Enter school email" required value="<%= typeof autofill !== 'undefined' && autofill.email ? autofill.email : '' %>">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="password">Password <span class="required">*</span></label>
            <input id="password" name="password" type="password" class="form-control" placeholder="Set a secure password" required oninput="validatePasswordStrength(this.value)">
            <small class="form-hint">
              • Minimum 8 characters<br>
              • At least 1 uppercase letter<br>
              • At least 1 lowercase letter<br>
              • At least 1 number<br>
              • At least 1 special character (!@#$%^&*)
            </small>
            <div id="password-strength" class="password-strength" style="margin-top: 10px; display: none;">
              <div class="strength-bar">
                <div class="strength-fill" id="strength-fill"></div>
              </div>
              <small id="strength-text" style="color: #666;"></small>
            </div>
          </div>

          <div class="form-group">
            <label for="location">Location <span class="required">*</span></label>
            <select id="location" name="location" class="form-control" required>
              <option value="">-- Select Location --</option>
              <% if (locations && locations.length > 0) { %>
                <% locations.forEach(loc => { %>
                  <option value="<%= loc %>" <%= typeof autofill !== 'undefined' && autofill.location === loc ? 'selected' : '' %>><%= loc %></option>
                <% }); %>
              <% } %>
            </select>
            <small class="form-hint">School will only see applicants from this location</small>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="genderFilter">Gender Filter <span class="required">*</span></label>
            <select id="genderFilter" name="genderFilter" class="form-control" required>
              <option value="">-- Select Gender Filter --</option>
              <option value="all" <%= typeof autofill !== 'undefined' && autofill.genderFilter === 'all' ? 'selected' : '' %>>All Genders</option>
              <option value="male" <%= typeof autofill !== 'undefined' && autofill.genderFilter === 'male' ? 'selected' : '' %>>Male Only</option>
              <option value="female" <%= typeof autofill !== 'undefined' && autofill.genderFilter === 'female' ? 'selected' : '' %>>Female Only</option>
            </select>
            <small class="form-hint">School will only see applicants of selected gender</small>
          </div>

        </div>

        <!-- Subscription Section -->
        <div class="subscription-section">
          <h3 class="subscription-title">Select Subscription Plan</h3>
          <div class="subscription-grid">
            <label class="subscription-card">
              <input type="radio" name="subscriptionTier" value="none" <%= (typeof autofill === 'undefined' || !autofill.subscriptionTier || autofill.subscriptionTier === 'none') ? 'checked' : '' %> class="subscription-radio">
              <div class="subscription-content">
                <div class="subscription-name">No Subscription</div>
                <div class="subscription-price">Free</div>
                <div class="subscription-duration">No Expiry</div>
              </div>
            </label>

            <label class="subscription-card">
              <input type="radio" name="subscriptionTier" value="silver" <%= typeof autofill !== 'undefined' && autofill.subscriptionTier === 'silver' ? 'checked' : '' %> class="subscription-radio">
              <div class="subscription-badge">Silver</div>
              <div class="subscription-content">
                <div class="subscription-name">Silver Plan</div>
                <div class="subscription-price">30 Days</div>
                <div class="subscription-duration">Basic Access</div>
              </div>
            </label>

            <label class="subscription-card">
              <input type="radio" name="subscriptionTier" value="gold" <%= typeof autofill !== 'undefined' && autofill.subscriptionTier === 'gold' ? 'checked' : '' %> class="subscription-radio">
              <div class="subscription-badge badge-gold">Gold</div>
              <div class="subscription-content">
                <div class="subscription-name">Gold Plan</div>
                <div class="subscription-price">6 Months</div>
                <div class="subscription-duration">Extended Access</div>
              </div>
            </label>

            <label class="subscription-card">
              <input type="radio" name="subscriptionTier" value="diamond" <%= typeof autofill !== 'undefined' && autofill.subscriptionTier === 'diamond' ? 'checked' : '' %> class="subscription-radio">
              <div class="subscription-badge badge-diamond">Diamond</div>
              <div class="subscription-content">
                <div class="subscription-name">Diamond Plan</div>
                <div class="subscription-price">1 Year</div>
                <div class="subscription-duration">Premium Access</div>
              </div>
            </label>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary btn-large">
            <span><i class="fa-solid fa-check"></i></span> Create Credential
          </button>
          <a href="/admin/credentials" class="btn btn-secondary btn-large">Cancel</a>
        </div>
      </form>
    </div>

    <!-- Quick Tips -->
    <div class="tips-card">
      <h3 class="tips-title"><i class="fa-solid fa-lightbulb"></i> Quick Tips</h3>
      <ul class="tips-list">
        <li><strong>Location Lock:</strong> Schools can only access applicants from their assigned location</li>
        <li><strong>Gender Filter:</strong> Further restricts which applicants the school can view</li>
        <li><strong>Validity:</strong> Set expiry to automatically disable access after a period</li>
        <li><strong>Security:</strong> Use strong, unique passwords for each school credential</li>
      </ul>
    </div>
    </section>
  </div>
</main>

<style>
  .credentials-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 20px;
    padding: 20px;
    background: #f5f7fa;
    min-height: 100vh;
  }

  .cred-sidebar {
    background: #fff;
    border: 1px solid #e7e9f0;
    border-radius: 12px;
    padding: 16px;
    height: fit-content;
    position: sticky;
    top: 20px;
  }

  .sidebar-brand {
    font-weight: 700;
    font-size: 14px;
    color: #1f2a44;
    margin-bottom: 12px;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    color: #1f2a44;
    text-decoration: none;
    border-radius: 8px;
    font-size: 13px;
    transition: background 0.2s;
  }

  .nav-item:hover {
    background: #f3f5fb;
  }

  .nav-item.active {
    background: #eef1f7;
    font-weight: 600;
  }

  .nav-icon {
    font-size: 16px;
    width: 18px;
  }

  .cred-main {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cred-topbar {
    background: #fff;
    border: 1px solid #e7e9f0;
    border-radius: 12px;
    padding: 12px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .topbar-left {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .page-title {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
    color: #1f2a44;
  }

  .page-subtitle {
    margin: 0;
    font-size: 12px;
    color: #6b7287;
  }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .icon-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid #e7e9f0;
    background: #fff;
    cursor: pointer;
    font-size: 18px;
    transition: all 0.2s;
  }

  .icon-btn:hover {
    background: #f6f7fb;
  }

  .user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #3b5ccc;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
  }

  .form-card {
    background: #fff;
    border: 1px solid #e7e9f0;
    border-radius: 12px;
    overflow: hidden;
  }

  .form-card-header {
    padding: 16px;
    border-bottom: 1px solid #e7e9f0;
    background: #f9fafb;
  }

  .form-card-title {
    margin: 0 0 4px 0;
    font-size: 15px;
    font-weight: 700;
    color: #1f2a44;
  }

  .form-card-desc {
    margin: 0;
    font-size: 12px;
    color: #6b7287;
  }

  .saas-form {
    padding: 20px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-weight: 600;
    color: #374151;
    font-size: 12px;
  }

  .required {
    color: #ef4444;
    font-weight: 700;
  }

  .form-control {
    padding: 10px 12px;
    border: 1px solid #e1e4ed;
    border-radius: 8px;
    font-size: 13px;
    transition: all 0.2s;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .form-control:focus {
    outline: none;
    border-color: #3b5ccc;
    box-shadow: 0 0 0 3px rgba(59, 92, 204, 0.1);
  }

  .form-control::placeholder {
    color: #9ca3af;
  }

  .form-hint {
    font-size: 11px;
    color: #6b7287;
    margin-top: 2px;
  }

  .form-actions {
    display: flex;
    gap: 10px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid #e7e9f0;
  }

  .btn {
    padding: 10px 18px;
    font-size: 13px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    justify-content: center;
  }

  .btn-large {
    padding: 12px 24px;
  }

  .btn-primary {
    background: #3b5ccc;
    color: #fff;
  }

  .btn-primary:hover {
    background: #2e4aaa;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(59, 92, 204, 0.2);
  }

  .btn-secondary {
    background: #f6f7fb;
    color: #424a63;
    border: 1px solid #e1e4ed;
  }

  .btn-secondary:hover {
    background: #e9ecf5;
  }

  .tips-card {
    background: #fff;
    border: 1px solid #e7e9f0;
    border-radius: 12px;
    padding: 16px;
  }

  .tips-title {
    margin: 0 0 12px 0;
    font-size: 14px;
    font-weight: 700;
    color: #1f2a44;
  }

  .tips-list {
    margin: 0;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .tips-list li {
    font-size: 12px;
    color: #424a63;
    line-height: 1.5;
  }

  .tips-list strong {
    color: #1f2a44;
  }

  .subscription-section {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 2px solid #e7e9f0;
  }

  .subscription-title {
    margin: 0 0 16px 0;
    font-size: 15px;
    font-weight: 700;
    color: #1f2a44;
  }

  .subscription-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }

  .subscription-card {
    position: relative;
    padding: 16px;
    border: 2px solid #e7e9f0;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s;
    background: #fff;
  }

  .subscription-card:hover {
    border-color: #3b5ccc;
    background: #f9fafb;
  }

  .subscription-radio {
    position: absolute;
    top: -6px;
    left: -6px;
    opacity: 0;
    cursor: pointer;
  }

  .subscription-radio:checked + .subscription-content {
    color: #3b5ccc;
  }

  .subscription-radio:checked ~ .subscription-badge {
    opacity: 1;
  }

  .subscription-card input[type="radio"]:checked {
    outline: 2px solid #3b5ccc;
    outline-offset: -6px;
  }

  .subscription-card:has(input:checked) {
    border-color: #3b5ccc;
    background: #eef1f7;
  }

  .subscription-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 4px 10px;
    background: #dbeafe;
    color: #1e40af;
    border-radius: 6px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    opacity: 0.7;
  }

  .subscription-badge.badge-gold {
    background: #fef3c7;
    color: #92400e;
  }

  .subscription-badge.badge-diamond {
    background: #f3e8ff;
    color: #6b21a8;
  }

  .subscription-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .subscription-name {
    font-weight: 600;
    font-size: 14px;
    color: #1f2a44;
  }

  .subscription-price {
    font-weight: 700;
    font-size: 16px;
    color: #3b5ccc;
  }

  .subscription-duration {
    font-size: 12px;
    color: #6b7287;
  }

  .alert {
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13px;
  }

  .alert-error {
    background: #fee2e2;
    color: #991b1b;
    border-left: 4px solid #ef4444;
  }

  .alert-success {
    background: #d1fae5;
    color: #065f46;
    border-left: 4px solid #10b981;
  }

  @media (max-width: 1024px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .credentials-layout {
      grid-template-columns: 1fr;
    }

    .cred-sidebar {
      position: static;
    }

    .form-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }
  }

  /* Password Strength Indicator */
  .password-strength {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .strength-bar {
    height: 6px;
    background: #e0e0e0;
    border-radius: 3px;
    overflow: hidden;
  }

  .strength-fill {
    height: 100%;
    background: #ef4444;
    width: 0%;
    transition: all 0.3s ease;
  }

  .strength-bar.weak .strength-fill { background: #ef4444; }
  .strength-bar.fair .strength-fill { background: #f59e0b; }
  .strength-bar.good .strength-fill { background: #eab308; }
  .strength-bar.strong .strength-fill { background: #10b981; }
</style>

<script>
  function validatePasswordStrength(password) {
    const strengthDisplay = document.getElementById('password-strength');
    const strengthFill = document.getElementById('strength-fill');
    const strengthText = document.getElementById('strength-text');
    
    if (!password) {
      strengthDisplay.style.display = 'none';
      return;
    }
    
    let score = 0;
    let feedback = [];
    
    // Length check
    if (password.length >= 8) score += 20;
    else feedback.push('Use 8+ characters');
    
    if (password.length >= 12) score += 10;
    if (password.length >= 16) score += 10;
    
    // Uppercase
    if (/[A-Z]/.test(password)) score += 15;
    else feedback.push('Add uppercase letter');
    
    // Lowercase
    if (/[a-z]/.test(password)) score += 15;
    else feedback.push('Add lowercase letter');
    
    // Numbers
    if (/[0-9]/.test(password)) score += 15;
    else feedback.push('Add number');
    
    // Special characters
    if (/[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(password)) score += 15;
    else feedback.push('Add special character (!@#$%^&*)');
    
    // Unique characters
    if (new Set(password).size >= 6) score += 0;
    
    score = Math.min(score, 100);
    
    let strength = 'Weak';
    let percentage = score;
    const bar = strengthFill.parentElement;
    
    bar.className = 'strength-bar';
    if (score < 30) {
      strength = '<i class="fa-solid fa-circle" style="color:#ef4444"></i> Weak';
      bar.classList.add('weak');
    } else if (score < 60) {
      strength = '<i class="fa-solid fa-circle" style="color:#f59e0b"></i> Fair';
      bar.classList.add('fair');
      percentage = 50;
    } else if (score < 80) {
      strength = '<i class="fa-solid fa-circle" style="color:#f59e0b"></i> Good';
      bar.classList.add('good');
      percentage = 75;
    } else {
      strength = '<i class="fa-solid fa-circle" style="color:#10b981"></i> Strong';
      bar.classList.add('strong');
      percentage = 100;
    }
    
    strengthFill.style.width = percentage + '%';
    strengthText.innerHTML = strength + (feedback.length > 0 ? ': ' + feedback.join(', ') : '');
    strengthDisplay.style.display = 'flex';
  }
</script>

<%- include('partials/footer') %>
